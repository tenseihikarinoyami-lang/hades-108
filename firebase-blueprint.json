{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the Hades Underworld system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's chosen display name" },
        "email": { "type": "string", "description": "User's email" },
        "photoURL": { "type": "string", "description": "URL to user's avatar/logo" },
        "role": { "type": "string", "enum": ["Juez", "Espectro"], "description": "User's role in the underworld" },
        "specterName": { "type": "string", "description": "The specific specter name chosen by the user" },
        "score": { "type": "number", "description": "Total trivia score" },
        "createdAt": { "type": "timestamp", "description": "When the user joined" }
      },
      "required": ["uid", "email", "role", "score"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message in the Underworld chat.",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The message content" },
        "uid": { "type": "string", "description": "Sender's UID" },
        "specterName": { "type": "string", "description": "Sender's specter name" },
        "photoURL": { "type": "string", "description": "Sender's avatar" },
        "createdAt": { "type": "timestamp", "description": "When the message was sent" }
      },
      "required": ["text", "uid", "createdAt"]
    },
    "TriviaScore": {
      "title": "TriviaScore",
      "description": "A user's score for a specific trivia category.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User's UID" },
        "specterName": { "type": "string", "description": "User's specter name" },
        "category": { "type": "string", "description": "Trivia category (e.g., 'LoL', 'Anime 90s')" },
        "score": { "type": "number", "description": "Score achieved" },
        "updatedAt": { "type": "timestamp", "description": "When the score was last updated" }
      },
      "required": ["uid", "category", "score", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores global chat messages."
    },
    "triviaScores/{scoreId}": {
      "schema": { "$ref": "#/entities/TriviaScore" },
      "description": "Stores high scores for trivias."
    }
  }
}
